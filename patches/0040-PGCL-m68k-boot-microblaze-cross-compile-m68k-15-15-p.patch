From 1fde4da3483555769a4ee3da4aa75d7c048361e4 Mon Sep 17 00:00:00 2001
From: Nadia Chambers <nadia.yvette.chambers@ik.me>
Date: Mon, 23 Mar 2026 18:40:27 +0100
Subject: [PATCH 040/174] =?UTF-8?q?PGCL:=20m68k=20boot=20+=20microblaze=20?=
 =?UTF-8?q?cross-compile=20=E2=80=94=20m68k=2015/15=20pgcl-test=20+=208/8?=
 =?UTF-8?q?=20pgcl-stress=20PASS?=
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

m68k (Motorola 68040 MMU):
- motorola.c: Use MMUPAGE_SIZE for PTE stride in map_node() linear mapping
  (hardware PTEs are 4KB, not PAGE_SIZE=64KB with PGCL)
- motorola.c: Use MMUPAGE_ALIGNED/MMUPAGE_SIZE in kernel_page_table() and
  kernel_ptr_table() for sub-table packing boundary detection (head.S
  allocates at 4KB hardware page granularity)
- motorola.c: Fix ptable_mask overflow — (1U << (PAGE_SIZE/ptable_size))
  overflows 32-bit unsigned when PAGE_SIZE=64KB; use MMUPAGE_SIZE
- motorola.c: Use MMUPAGE_MASK in init_pointer_table/free_pointer_table
  for sub-table offset calculation within hardware pages
- motorola_pgtable.h: _PAGE_CHG_MASK uses MMUPAGE_MASK to preserve
  sub-page bits in pte_modify()
- m68k boots on QEMU virt, SMP=1, all 23 tests PASS, zero warnings

microblaze (software TLB, 2-level page table):
- page.h: PTE_SHIFT = MMUPAGE_SHIFT-2 (1024 PTEs per hardware page)
- pgtable.h: PGDIR_SHIFT = MMUPAGE_SHIFT+PTE_SHIFT, _PAGE_CHG_MASK
- fixmap.h: FIXADDR_TOP/SIZE use MMUPAGE_SIZE/SHIFT
- highmem.h: PKMAP_BASE/NR/ADDR use MMUPAGE_SIZE/SHIFT
- elf.h: ELF_EXEC_PAGESIZE = 4096 (hardcoded, MMUPAGE_SIZE unavailable in UAPI)
- signal.c: Trampoline offset uses MMUPAGE_MASK
- Cross-compile PASS (MMUSHIFT=0 and MMUSHIFT=4)
- Boot blocked by baseline QEMU fork() SIGSEGV (pre-existing, not PGCL)

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
---
 arch/m68k/include/asm/motorola_pgtable.h |  2 +-
 arch/m68k/mm/motorola.c                  | 41 +++++++++++++++---------
 arch/microblaze/include/asm/fixmap.h     |  4 +--
 arch/microblaze/include/asm/highmem.h    |  6 ++--
 arch/microblaze/include/asm/page.h       |  2 +-
 arch/microblaze/include/asm/pgtable.h    |  4 +--
 arch/microblaze/include/uapi/asm/elf.h   |  2 +-
 arch/microblaze/kernel/signal.c          |  2 +-
 8 files changed, 36 insertions(+), 27 deletions(-)

diff --git a/arch/m68k/include/asm/motorola_pgtable.h b/arch/m68k/include/asm/motorola_pgtable.h
index dcf6829b3eab..78bdc6036f7a 100644
--- a/arch/m68k/include/asm/motorola_pgtable.h
+++ b/arch/m68k/include/asm/motorola_pgtable.h
@@ -37,7 +37,7 @@
 #define _TABLE_MASK	(0xffffff00)
 
 #define _PAGE_TABLE	(_PAGE_SHORT)
-#define _PAGE_CHG_MASK  (PAGE_MASK | _PAGE_ACCESSED | _PAGE_DIRTY | _PAGE_NOCACHE)
+#define _PAGE_CHG_MASK  (MMUPAGE_MASK | _PAGE_ACCESSED | _PAGE_DIRTY | _PAGE_NOCACHE)
 
 #define _PAGE_PROTNONE	0x004
 
diff --git a/arch/m68k/mm/motorola.c b/arch/m68k/mm/motorola.c
index b30aa69a73a6..54a98013e36f 100644
--- a/arch/m68k/mm/motorola.c
+++ b/arch/m68k/mm/motorola.c
@@ -114,13 +114,13 @@ static const int ptable_shift[3] = {
 };
 
 #define ptable_size(type) (1U << ptable_shift[type])
-#define ptable_mask(type) ((1U << (PAGE_SIZE / ptable_size(type))) - 1)
+#define ptable_mask(type) ((1U << (MMUPAGE_SIZE / ptable_size(type))) - 1)
 
 void __init init_pointer_table(void *table, int type)
 {
 	ptable_desc *dp;
 	unsigned long ptable = (unsigned long)table;
-	unsigned long pt_addr = ptable & PAGE_MASK;
+	unsigned long pt_addr = ptable & MMUPAGE_MASK;
 	unsigned int mask = 1U << ((ptable - pt_addr)/ptable_size(type));
 
 	dp = PD_PTABLE(pt_addr);
@@ -201,7 +201,7 @@ int free_pointer_table(void *table, int type)
 {
 	ptable_desc *dp;
 	unsigned long ptable = (unsigned long)table;
-	unsigned long pt_addr = ptable & PAGE_MASK;
+	unsigned long pt_addr = ptable & MMUPAGE_MASK;
 	unsigned int mask = 1U << ((ptable - pt_addr)/ptable_size(type));
 
 	dp = PD_PTABLE(pt_addr);
@@ -237,14 +237,19 @@ static pte_t * __init kernel_page_table(void)
 {
 	pte_t *pte_table = last_pte_table;
 
-	if (PAGE_ALIGNED(last_pte_table)) {
-		pte_table = memblock_alloc_low(PAGE_SIZE, PAGE_SIZE);
+	/*
+	 * Pack multiple PTE tables per hardware page (MMUPAGE_SIZE).
+	 * Must use MMUPAGE_ALIGNED, not PAGE_ALIGNED, because head.S
+	 * allocates at hardware page granularity (4KB).
+	 */
+	if (MMUPAGE_ALIGNED(last_pte_table)) {
+		pte_table = memblock_alloc_low(MMUPAGE_SIZE, MMUPAGE_SIZE);
 		if (!pte_table) {
 			panic("%s: Failed to allocate %lu bytes align=%lx\n",
-					__func__, PAGE_SIZE, PAGE_SIZE);
+					__func__, MMUPAGE_SIZE, MMUPAGE_SIZE);
 		}
 
-		clear_page(pte_table);
+		memset(pte_table, 0, MMUPAGE_SIZE);
 		mmu_page_ctor(pte_table);
 
 		last_pte_table = pte_table;
@@ -285,13 +290,17 @@ static pmd_t * __init kernel_ptr_table(void)
 	}
 
 	last_pmd_table += PTRS_PER_PMD;
-	if (PAGE_ALIGNED(last_pmd_table)) {
-		last_pmd_table = memblock_alloc_low(PAGE_SIZE, PAGE_SIZE);
+	/*
+	 * Pack multiple PMD tables per hardware page (MMUPAGE_SIZE).
+	 * Must use MMUPAGE_ALIGNED because head.S allocates at 4KB.
+	 */
+	if (MMUPAGE_ALIGNED(last_pmd_table)) {
+		last_pmd_table = memblock_alloc_low(MMUPAGE_SIZE, MMUPAGE_SIZE);
 		if (!last_pmd_table)
 			panic("%s: Failed to allocate %lu bytes align=%lx\n",
-			      __func__, PAGE_SIZE, PAGE_SIZE);
+			      __func__, MMUPAGE_SIZE, MMUPAGE_SIZE);
 
-		clear_page(last_pmd_table);
+		memset(last_pmd_table, 0, MMUPAGE_SIZE);
 		mmu_page_ctor(last_pmd_table);
 	}
 
@@ -362,8 +371,8 @@ static void __init map_node(int node)
 				pmd_set(pmd_dir, pte_dir);
 
 				pte_val(*pte_dir++) = 0;
-				physaddr += PAGE_SIZE;
-				for (i = 1; i < PTRS_PER_PTE; physaddr += PAGE_SIZE, i++)
+				physaddr += MMUPAGE_SIZE;
+				for (i = 1; i < PTRS_PER_PTE; physaddr += MMUPAGE_SIZE, i++)
 					pte_val(*pte_dir++) = physaddr;
 			}
 			size -= PMD_SIZE;
@@ -383,9 +392,9 @@ static void __init map_node(int node)
 					pte_val(*pte_dir) = physaddr;
 			} else
 				pte_val(*pte_dir) = 0;
-			size -= PAGE_SIZE;
-			virtaddr += PAGE_SIZE;
-			physaddr += PAGE_SIZE;
+			size -= MMUPAGE_SIZE;
+			virtaddr += MMUPAGE_SIZE;
+			physaddr += MMUPAGE_SIZE;
 		}
 
 	}
diff --git a/arch/microblaze/include/asm/fixmap.h b/arch/microblaze/include/asm/fixmap.h
index f9797849e4d4..45403bcafee8 100644
--- a/arch/microblaze/include/asm/fixmap.h
+++ b/arch/microblaze/include/asm/fixmap.h
@@ -23,7 +23,7 @@
 #include <asm/kmap_size.h>
 #endif
 
-#define FIXADDR_TOP	((unsigned long)(-PAGE_SIZE))
+#define FIXADDR_TOP	((unsigned long)(-MMUPAGE_SIZE))
 
 /*
  * Here we define all the compile-time 'special' virtual
@@ -55,7 +55,7 @@ enum fixed_addresses {
 extern void __set_fixmap(enum fixed_addresses idx,
 					phys_addr_t phys, pgprot_t flags);
 
-#define __FIXADDR_SIZE	(__end_of_fixed_addresses << PAGE_SHIFT)
+#define __FIXADDR_SIZE	(__end_of_fixed_addresses << MMUPAGE_SHIFT)
 #define FIXADDR_START		(FIXADDR_TOP - __FIXADDR_SIZE)
 
 #define FIXMAP_PAGE_NOCACHE PAGE_KERNEL_CI
diff --git a/arch/microblaze/include/asm/highmem.h b/arch/microblaze/include/asm/highmem.h
index 4418633fb163..078c0f71f535 100644
--- a/arch/microblaze/include/asm/highmem.h
+++ b/arch/microblaze/include/asm/highmem.h
@@ -42,12 +42,12 @@ extern pte_t *pkmap_page_table;
 #define PKMAP_ORDER	PTE_SHIFT
 #define LAST_PKMAP	(1 << PKMAP_ORDER)
 
-#define PKMAP_BASE	((FIXADDR_START - PAGE_SIZE * (LAST_PKMAP + 1)) \
+#define PKMAP_BASE	((FIXADDR_START - MMUPAGE_SIZE * (LAST_PKMAP + 1)) \
 								& PMD_MASK)
 
 #define LAST_PKMAP_MASK	(LAST_PKMAP - 1)
-#define PKMAP_NR(virt)  ((virt - PKMAP_BASE) >> PAGE_SHIFT)
-#define PKMAP_ADDR(nr)  (PKMAP_BASE + ((nr) << PAGE_SHIFT))
+#define PKMAP_NR(virt)  ((virt - PKMAP_BASE) >> MMUPAGE_SHIFT)
+#define PKMAP_ADDR(nr)  (PKMAP_BASE + ((nr) << MMUPAGE_SHIFT))
 
 #define flush_cache_kmaps()	{ flush_icache(); flush_dcache(); }
 
diff --git a/arch/microblaze/include/asm/page.h b/arch/microblaze/include/asm/page.h
index e1e396367ba7..63ed27f038f8 100644
--- a/arch/microblaze/include/asm/page.h
+++ b/arch/microblaze/include/asm/page.h
@@ -23,7 +23,7 @@
 
 #define LOAD_OFFSET	ASM_CONST((CONFIG_KERNEL_START-CONFIG_KERNEL_BASE_ADDR))
 
-#define PTE_SHIFT	(PAGE_SHIFT - 2)	/* 1024 ptes per page */
+#define PTE_SHIFT	(MMUPAGE_SHIFT - 2)	/* 1024 ptes per MMUPAGE */
 
 #ifndef __ASSEMBLER__
 
diff --git a/arch/microblaze/include/asm/pgtable.h b/arch/microblaze/include/asm/pgtable.h
index 7678c040a2fd..1e5a824faf8d 100644
--- a/arch/microblaze/include/asm/pgtable.h
+++ b/arch/microblaze/include/asm/pgtable.h
@@ -86,7 +86,7 @@ extern pte_t *va_to_pte(unsigned long address);
  */
 
 /* PGDIR_SHIFT determines what a top-level page table entry can map */
-#define PGDIR_SHIFT	(PAGE_SHIFT + PTE_SHIFT)
+#define PGDIR_SHIFT	(MMUPAGE_SHIFT + PTE_SHIFT)
 #define PGDIR_SIZE	(1UL << PGDIR_SHIFT)
 #define PGDIR_MASK	(~(PGDIR_SIZE-1))
 
@@ -173,7 +173,7 @@ extern pte_t *va_to_pte(unsigned long address);
 #define _PAGE_EXEC	0
 #endif
 
-#define _PAGE_CHG_MASK	(PAGE_MASK | _PAGE_ACCESSED | _PAGE_DIRTY)
+#define _PAGE_CHG_MASK	(MMUPAGE_MASK | _PAGE_ACCESSED | _PAGE_DIRTY)
 
 /*
  * Note: the _PAGE_COHERENT bit automatically gets set in the hardware
diff --git a/arch/microblaze/include/uapi/asm/elf.h b/arch/microblaze/include/uapi/asm/elf.h
index 6b656de29f00..ad8d8bb7d8c0 100644
--- a/arch/microblaze/include/uapi/asm/elf.h
+++ b/arch/microblaze/include/uapi/asm/elf.h
@@ -81,7 +81,7 @@ typedef elf_fpreg_t elf_fpregset_t[ELF_NFPREG];
 #define ELF_DATA	ELFDATA2MSB
 #endif
 
-#define ELF_EXEC_PAGESIZE	PAGE_SIZE
+#define ELF_EXEC_PAGESIZE	4096
 
 
 #define ELF_CORE_COPY_REGS(_dest, _regs)			\
diff --git a/arch/microblaze/kernel/signal.c b/arch/microblaze/kernel/signal.c
index c78a0ff48066..c79c7fa4acf3 100644
--- a/arch/microblaze/kernel/signal.c
+++ b/arch/microblaze/kernel/signal.c
@@ -197,7 +197,7 @@ static int setup_rt_frame(struct ksignal *ksig, sigset_t *set,
 	if (ptep && pte_present(*ptep)) {
 		address = (unsigned long) page_address(pte_page(*ptep));
 		/* MS: I need add offset in page */
-		address += ((unsigned long)frame->tramp) & ~PAGE_MASK;
+		address += ((unsigned long)frame->tramp) & ~MMUPAGE_MASK;
 		/* MS address is virtual */
 		address = __virt_to_phys(address);
 		invalidate_icache_range(address, address + 8);
