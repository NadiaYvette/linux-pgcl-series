From 31db9a975cfccb0745e55c2fbd0e2d5bf87bac46 Mon Sep 17 00:00:00 2001
From: Nadia Yvette Chambers <nadia.yvette.chambers@ik.me>
Date: Sun, 14 Jun 2026 18:04:07 +0200
Subject: [PATCH 151/174] x86/perf, mm/pgcl: size the Debug Store area and
 buffers in MMUPAGE units

Under page clustering (CONFIG_PAGE_MMUSHIFT > 0) PAGE_SIZE is large (256K at
shift 6).  struct debug_store is __aligned(PAGE_SIZE) and the BTS/PEBS trace
buffers are sized PAGE_SIZE << 4, so at shift 6 the DS area balloons to 256K and
each buffer to 4M.  That:
  - pushes sizeof(struct bts_ctx) (which embeds a struct debug_store) past
    PCPU_MIN_UNIT_SIZE, so bts_init()'s alloc_percpu() trips "illegal size (...)
    for percpu allocation" and BTS fails to register;
  - inflates struct cpu_entry_area (it embeds the DS area + an 8M
    debug_store_buffers), wasting cpu_entry_area space per CPU.

The DS area and its buffers are hardware structures mapped into the
cpu_entry_area at hardware-page granularity (cea_set_pte()/cea_map_percpu_pages()
already stride MMUPAGE_SIZE), so size them in MMUPAGE units, not the clustering
PAGE:
  - struct debug_store: __aligned(MMUPAGE_SIZE);
  - BTS_BUFFER_SIZE / PEBS_BUFFER_SIZE: MMUPAGE_SIZE << 4 (the intended ~64K);
  - ARCH_PEBS_THRESH_MULTI: subtract one MMUPAGE (hardware page) margin.

The cpu_entry_area is built and mapped at MMUPAGE granularity, so relax the
get_cpu_entry_area() assertion from PAGE_SIZE to MMUPAGE_SIZE; the PAGE_SIZE form
only held before because the un-MMUPAGE'd DS area/buffers were coincidentally
PAGE multiples.

All substitutions are MMUPAGE_SIZE-for-PAGE_SIZE, identity at PAGE_MMUSHIFT == 0.
Build-verified at PAGE_MMUSHIFT=6 and 0.  Runtime confirmation of the BTS percpu
WARN needs Intel BTS hardware (not exposed under QEMU/KVM), i.e. the laptop.

Co-Authored-By: Claude Opus 4.8 <noreply@anthropic.com>
---
 arch/x86/include/asm/intel_ds.h | 26 +++++++++++++++++++++-----
 arch/x86/mm/cpu_entry_area.c    | 10 +++++++++-
 2 files changed, 30 insertions(+), 6 deletions(-)

diff --git a/arch/x86/include/asm/intel_ds.h b/arch/x86/include/asm/intel_ds.h
index 695f87efbeb8..39c2aaf1447a 100644
--- a/arch/x86/include/asm/intel_ds.h
+++ b/arch/x86/include/asm/intel_ds.h
@@ -3,15 +3,22 @@
 
 #include <linux/percpu-defs.h>
 
-#define BTS_BUFFER_SIZE		(PAGE_SIZE << 4)
+/*
+ * The BTS and PEBS trace buffers are hardware-written byte buffers sized in
+ * hardware pages.  Under page clustering use MMUPAGE_SIZE, not the (large)
+ * kernel PAGE_SIZE, so the buffers -- and the cpu_entry_area that maps them --
+ * stay the intended ~64K rather than ballooning (e.g. to 4M at PAGE_MMUSHIFT=6).
+ * Identity at PAGE_MMUSHIFT == 0 (MMUPAGE_SIZE == PAGE_SIZE).
+ */
+#define BTS_BUFFER_SIZE		(MMUPAGE_SIZE << 4)
 #define PEBS_BUFFER_SHIFT	4
-#define PEBS_BUFFER_SIZE	(PAGE_SIZE << PEBS_BUFFER_SHIFT)
+#define PEBS_BUFFER_SIZE	(MMUPAGE_SIZE << PEBS_BUFFER_SHIFT)
 
 /*
- * The largest PEBS record could consume a page, ensure
+ * The largest PEBS record could consume a hardware page, ensure
  * a record at least can be written after triggering PMI.
  */
-#define ARCH_PEBS_THRESH_MULTI	((PEBS_BUFFER_SIZE - PAGE_SIZE) >> PEBS_BUFFER_SHIFT)
+#define ARCH_PEBS_THRESH_MULTI	((PEBS_BUFFER_SIZE - MMUPAGE_SIZE) >> PEBS_BUFFER_SHIFT)
 #define ARCH_PEBS_THRESH_SINGLE	1
 
 /* The maximal number of PEBS events: */
@@ -35,7 +42,16 @@ struct debug_store {
 	u64	pebs_absolute_maximum;
 	u64	pebs_interrupt_threshold;
 	u64	pebs_event_reset[MAX_PEBS_EVENTS + MAX_FIXED_PEBS_EVENTS];
-} __aligned(PAGE_SIZE);
+	/*
+	 * The DS area is a hardware structure mapped into the cpu_entry_area at
+	 * hardware-page granularity; align to MMUPAGE_SIZE, not the kernel
+	 * PAGE_SIZE.  Otherwise under page clustering each embedded/percpu copy
+	 * balloons to a full (e.g. 256K) PAGE -- inflating the cpu_entry_area and
+	 * pushing alloc_percpu(struct bts_ctx) past PCPU_MIN_UNIT_SIZE in
+	 * bts_init() (the "illegal size for percpu allocation" WARN).  Identity at
+	 * PAGE_MMUSHIFT == 0 (MMUPAGE_SIZE == PAGE_SIZE).
+	 */
+} __aligned(MMUPAGE_SIZE);
 
 DECLARE_PER_CPU_PAGE_ALIGNED(struct debug_store, cpu_debug_store);
 
diff --git a/arch/x86/mm/cpu_entry_area.c b/arch/x86/mm/cpu_entry_area.c
index fe356df50749..a981efc2f764 100644
--- a/arch/x86/mm/cpu_entry_area.c
+++ b/arch/x86/mm/cpu_entry_area.c
@@ -70,7 +70,15 @@ static inline void init_cea_offsets(void) { }
 noinstr struct cpu_entry_area *get_cpu_entry_area(int cpu)
 {
 	unsigned long va = CPU_ENTRY_AREA_PER_CPU + cea_offset(cpu) * CPU_ENTRY_AREA_SIZE;
-	BUILD_BUG_ON(sizeof(struct cpu_entry_area) % PAGE_SIZE != 0);
+	/*
+	 * The cpu_entry_area is built and mapped at hardware-page (MMUPAGE)
+	 * granularity (see cea_set_pte()/cea_map_percpu_pages()), so each CPU's
+	 * area need only be an MMUPAGE multiple, not a full kernel PAGE multiple.
+	 * Asserting PAGE_SIZE here would force every sub-structure (e.g. the DS
+	 * area and its buffers) up to a full PAGE under page clustering.  Identity
+	 * at PAGE_MMUSHIFT == 0 (MMUPAGE_SIZE == PAGE_SIZE).
+	 */
+	BUILD_BUG_ON(sizeof(struct cpu_entry_area) % MMUPAGE_SIZE != 0);
 
 	return (struct cpu_entry_area *) va;
 }
