From 5d85d1731e18cc3cd9725987985dd91f6e84200e Mon Sep 17 00:00:00 2001
From: Nadia Chambers <nadia.yvette.chambers@ik.me>
Date: Tue, 19 May 2026 09:43:49 +0200
Subject: [PATCH 119/174] sparc64: skip hugetlb hstates whose order <
 order_base_2(__NR_USED_SUBPAGE)

mm/hugetlb.c's hugetlb_add_hstate has:

  BUG_ON(order < order_base_2(__NR_USED_SUBPAGE));

This requires a hstate to have at least __NR_USED_SUBPAGE (== 3)
sub-pages so the tail-page bookkeeping fits.  Under PGCL
(PAGE_SHIFT = MMUPAGE_SHIFT + CONFIG_PAGE_MMUSHIFT) the kernel PAGE
grows past a given HPAGE_*_SHIFT, in which case the corresponding
hstate has too few sub-pages.

Concretely on sparc64 (MMUPAGE_SHIFT == 13):

  PGCL=2 (PAGE_SHIFT=15):
    HPAGE_64K_SHIFT - PAGE_SHIFT = 16 - 15 = 1
    The existing gate `HPAGE_64K_SHIFT > PAGE_SHIFT` (16 > 15) is TRUE
    so hugetlb_add_hstate(1) is called, BUG_ON(1 < 2) fires:

      kernel BUG at mm/hugetlb.c:4183!
      Call Trace:
        [<...>] hugetlb_add_hstate+0x9c/0x198
        [<...>] hugetlbpage_init+0x8/0x30
        [<...>] do_one_initcall+0x4c/0x2a0
        [<...>] kernel_init_freeable+0x204/0x28c
        [<...>] kernel_init+0x14/0x128
        [<...>] ret_from_fork+0x24/0x34

    init = PID 1 dies, kernel panics, system reboot-loops forever.

  PGCL=4 (PAGE_SHIFT=17): the existing > PAGE_SHIFT gate already
    skips the 64K case (16 > 17 is FALSE), so PGCL=4/6 are not
    affected today.  The other sizes (8M/256M/2G) all yield order
    >= 4 at PGCL=6, so they happen to be safe.

Tighten the existing > PAGE_SHIFT gate to require
order >= order_base_2(__NR_USED_SUBPAGE), and apply the same gate
uniformly to the 8M/256M/2G calls so future PGCL bumps are not
load-bearing for these arithmetic margins.

Verified: sparc64 PGCL=2 boots, hugetlbfs registers 8.00 MiB and 256
MiB page sizes, init runs, no kernel BUG.  Previously panicked on
the BUG_ON inside hugetlb_add_hstate in arch_initcall(hugetlbpage_init).

Co-Authored-By: Claude Opus 4.7 <noreply@anthropic.com>
---
 arch/sparc/mm/init_64.c | 33 ++++++++++++++++++++++++++++-----
 1 file changed, 28 insertions(+), 5 deletions(-)

diff --git a/arch/sparc/mm/init_64.c b/arch/sparc/mm/init_64.c
index adf9e68d9bf7..3e7f9540aeed 100644
--- a/arch/sparc/mm/init_64.c
+++ b/arch/sparc/mm/init_64.c
@@ -330,11 +330,34 @@ static void __update_mmu_tsb_insert(struct mm_struct *mm, unsigned long tsb_inde
 #ifdef CONFIG_HUGETLB_PAGE
 static int __init hugetlbpage_init(void)
 {
-	if (HPAGE_64K_SHIFT > PAGE_SHIFT)
-		hugetlb_add_hstate(HPAGE_64K_SHIFT - PAGE_SHIFT);
-	hugetlb_add_hstate(HPAGE_SHIFT - PAGE_SHIFT);
-	hugetlb_add_hstate(HPAGE_256MB_SHIFT - PAGE_SHIFT);
-	hugetlb_add_hstate(HPAGE_2GB_SHIFT - PAGE_SHIFT);
+	/*
+	 * mm/hugetlb.c BUG_ONs hugetlb_add_hstate with order <
+	 * order_base_2(__NR_USED_SUBPAGE) (== 2): a hstate must have
+	 * at least __NR_USED_SUBPAGE sub-pages for tail-page bookkeeping.
+	 * Under PGCL (PAGE_SHIFT = MMUPAGE_SHIFT + CONFIG_PAGE_MMUSHIFT)
+	 * the kernel PAGE can grow past a given HPAGE_*_SHIFT, in which
+	 * case the corresponding hstate has too few (or zero) sub-pages.
+	 *
+	 * Concretely on sparc64 (MMUPAGE_SHIFT == 13):
+	 *   PGCL=2 (PAGE_SHIFT=15) HPAGE_64K_SHIFT - PAGE_SHIFT = 1 → BUG
+	 *   PGCL=4 (PAGE_SHIFT=17) HPAGE_64K_SHIFT - PAGE_SHIFT < 0 (handled
+	 *     by the existing > PAGE_SHIFT gate)
+	 * The larger sizes are safe up to PGCL=6 today, but apply the
+	 * same guard uniformly so future PGCL bumps are not load-bearing
+	 * for these arithmetic margins.
+	 */
+#define ADD_HSTATE_IF_FITS(shift) do {					\
+	int __order = (int)(shift) - PAGE_SHIFT;			\
+	if (__order >= order_base_2(__NR_USED_SUBPAGE))			\
+		hugetlb_add_hstate(__order);				\
+} while (0)
+
+	ADD_HSTATE_IF_FITS(HPAGE_64K_SHIFT);
+	ADD_HSTATE_IF_FITS(HPAGE_SHIFT);
+	ADD_HSTATE_IF_FITS(HPAGE_256MB_SHIFT);
+	ADD_HSTATE_IF_FITS(HPAGE_2GB_SHIFT);
+
+#undef ADD_HSTATE_IF_FITS
 
 	return 0;
 }
