--- a/arch/microblaze/kernel/sys_microblaze.c
+++ b/arch/microblaze/kernel/sys_microblaze.c
@@ -37,19 +37,19 @@ SYSCALL_DEFINE6(mmap, unsigned long, addr, unsigned long, len,
