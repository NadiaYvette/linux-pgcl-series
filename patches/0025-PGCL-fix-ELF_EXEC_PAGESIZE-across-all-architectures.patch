 arch/riscv/include/asm/elf.h     | 2 +-
 arch/s390/include/asm/elf.h      | 2 +-
 arch/sparc/include/asm/elf_64.h  | 2 +-
 7 files changed, 7 insertions(+), 7 deletions(-)

