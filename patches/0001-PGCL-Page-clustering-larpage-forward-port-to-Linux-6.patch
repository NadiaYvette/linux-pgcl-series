 #include <uapi/linux/const.h>
 
 /*
- * PAGE_SHIFT determines the page size.
+ * MMUPAGE_SHIFT is the hardware MMU page shift (from arch Kconfig).
+ * PAGE_MMUSHIFT is the extra shift for page clustering (Hugh Dickins, 2001).
