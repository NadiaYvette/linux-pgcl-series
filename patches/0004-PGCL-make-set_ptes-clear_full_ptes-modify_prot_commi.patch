From 9dceccfdfb7bf87ce18f16676a783f6494564afb Mon Sep 17 00:00:00 2001
From: Nadia Chambers <nadia.yvette.chambers@ik.me>
Date: Thu, 5 Mar 2026 07:25:07 +0100
Subject: [PATCH 004/174] PGCL: make
 set_ptes/clear_full_ptes/modify_prot_commit_ptes MMUPAGE-aware

With page clustering, each kernel page spans PAGE_MMUCOUNT MMUPAGEs.
Fix PTE batch operations to handle MMUPAGE granularity:

- set_ptes(): When nr>1 (large folio batched mapping), expand each
  kernel page into PAGE_MMUCOUNT PTEs with sub-page offsets via
  __pte(pte_val(pte) + j * MMUPAGE_SIZE). When nr==1, preserve
  existing single-PTE behavior (caller already set sub-page offset).

- get_and_clear_full_ptes(): Step addr by MMUPAGE_SIZE between PTEs
  instead of PAGE_SIZE.

- clear_full_ptes(): Same MMUPAGE_SIZE stepping fix.

- modify_prot_commit_ptes(): Same MMUPAGE_SIZE stepping fix.

Tested: PAGE_MMUSHIFT=0 and PAGE_MMUSHIFT=2 boot with 8/8 tests passing.

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
---
 include/linux/pgtable.h | 35 ++++++++++++++++++++++++++++++++---
 1 file changed, 32 insertions(+), 3 deletions(-)

diff --git a/include/linux/pgtable.h b/include/linux/pgtable.h
index 7c4d6a49a1ca..dc2c72f8fcf5 100644
--- a/include/linux/pgtable.h
+++ b/include/linux/pgtable.h
@@ -410,6 +410,34 @@ static inline pte_t pte_advance_pfn(pte_t pte, unsigned long nr)
 static inline void set_ptes(struct mm_struct *mm, unsigned long addr,
 		pte_t *ptep, pte_t pte, unsigned int nr)
 {
+#if PAGE_MMUSHIFT > 0
+	page_table_check_ptes_set(mm, addr, ptep, pte, nr);
+
+	if (nr == 1) {
+		/* Single PTE: caller already set up sub-page offset */
+		set_pte(ptep, pte);
+	} else {
+		unsigned int i;
+
+		/*
+		 * With page clustering, nr is in kernel pages but each
+		 * kernel page spans PAGE_MMUCOUNT MMUPAGEs.  Fill
+		 * nr * PAGE_MMUCOUNT PTEs, using sub-page offsets
+		 * within each kernel page.
+		 */
+		for (i = 0; i < nr; i++) {
+			unsigned int j;
+
+			for (j = 0; j < PAGE_MMUCOUNT; j++) {
+				set_pte(ptep, __pte(pte_val(pte) +
+						    j * MMUPAGE_SIZE));
+				ptep++;
+			}
+			if (i + 1 < nr)
+				pte = pte_next_pfn(pte);
+		}
+	}
+#else
 	page_table_check_ptes_set(mm, addr, ptep, pte, nr);
 
 	for (;;) {
@@ -419,6 +447,7 @@ static inline void set_ptes(struct mm_struct *mm, unsigned long addr,
 		ptep++;
 		pte = pte_next_pfn(pte);
 	}
+#endif
 }
 #endif
 #define set_pte_at(mm, addr, ptep, pte) set_ptes(mm, addr, ptep, pte, 1)
@@ -845,7 +874,7 @@ static inline pte_t get_and_clear_full_ptes(struct mm_struct *mm,
 	pte = ptep_get_and_clear_full(mm, addr, ptep, full);
 	while (--nr) {
 		ptep++;
-		addr += PAGE_SIZE;
+		addr += MMUPAGE_SIZE;
 		tmp_pte = ptep_get_and_clear_full(mm, addr, ptep, full);
 		if (pte_dirty(tmp_pte))
 			pte = pte_mkdirty(pte);
@@ -906,7 +935,7 @@ static inline void clear_full_ptes(struct mm_struct *mm, unsigned long addr,
 		if (--nr == 0)
 			break;
 		ptep++;
-		addr += PAGE_SIZE;
+		addr += MMUPAGE_SIZE;
 	}
 }
 #endif
@@ -1689,7 +1718,7 @@ static inline void modify_prot_commit_ptes(struct vm_area_struct *vma, unsigned
 {
 	int i;
 
-	for (i = 0; i < nr; ++i, ++ptep, addr += PAGE_SIZE) {
+	for (i = 0; i < nr; ++i, ++ptep, addr += MMUPAGE_SIZE) {
 		ptep_modify_prot_commit(vma, addr, ptep, old_pte, pte);
 
 		/* Advance PFN only, set same prot */
