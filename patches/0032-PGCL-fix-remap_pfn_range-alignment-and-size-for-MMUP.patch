From 0b75ed651292873ecdbbb2bda764b16ab37bfb05 Mon Sep 17 00:00:00 2001
From: Nadia Chambers <nadia.yvette.chambers@ik.me>
Date: Sat, 21 Mar 2026 06:45:24 +0100
Subject: [PATCH 032/174] PGCL: fix remap_pfn_range alignment and size for
 MMUPAGE granularity

remap_pfn_range maps PTEs at MMUPAGE granularity, but used PAGE_ALIGNED()
for the address check and PAGE_ALIGN() for size rounding. With MMUSHIFT=4,
PAGE_SIZE=64KB (or larger), so MMUPAGE-aligned addresses that aren't
PAGE-aligned trigger WARN_ON_ONCE. Similarly, PAGE_ALIGN rounds size up
to a full kernel page when only MMUPAGE alignment is needed.

Fix: use MMUPAGE_ALIGNED/MMUPAGE_ALIGN in remap_pfn_range_internal,
remap_pfn_range_track, and remap_pfn_range_prepare_vma.

Exposed by the pfnmap mm selftest which exercises remap_pfn_range
with MMUPAGE-aligned addresses.

Co-Authored-By: Claude Opus 4.6 <noreply@anthropic.com>
---
 mm/memory.c | 8 ++++----
 1 file changed, 4 insertions(+), 4 deletions(-)

diff --git a/mm/memory.c b/mm/memory.c
index 5642a8b96682..78c25f4f43ba 100644
--- a/mm/memory.c
+++ b/mm/memory.c
@@ -3190,11 +3190,11 @@ static int remap_pfn_range_internal(struct vm_area_struct *vma, unsigned long ad
 {
 	pgd_t *pgd;
 	unsigned long next;
-	unsigned long end = addr + PAGE_ALIGN(size);
+	unsigned long end = addr + MMUPAGE_ALIGN(size);
 	struct mm_struct *mm = vma->vm_mm;
 	int err;
 
-	if (WARN_ON_ONCE(!PAGE_ALIGNED(addr)))
+	if (WARN_ON_ONCE(!MMUPAGE_ALIGNED(addr)))
 		return -EINVAL;
 
 	VM_WARN_ON_ONCE(!vma_test_all_mask(vma, VMA_REMAP_FLAGS));
@@ -3270,7 +3270,7 @@ static int remap_pfn_range_track(struct vm_area_struct *vma, unsigned long addr,
 	struct pfnmap_track_ctx *ctx = NULL;
 	int err;
 
-	size = PAGE_ALIGN(size);
+	size = MMUPAGE_ALIGN(size);
 
 	/*
 	 * If we cover the full VMA, we'll perform actual tracking, and
@@ -3339,7 +3339,7 @@ static int remap_pfn_range_prepare_vma(struct vm_area_struct *vma,
 				       unsigned long addr, unsigned long pfn,
 				       unsigned long size)
 {
-	const unsigned long end = addr + PAGE_ALIGN(size);
+	const unsigned long end = addr + MMUPAGE_ALIGN(size);
 	const bool is_cow = is_cow_mapping(vma->vm_flags);
 	int err;
 
