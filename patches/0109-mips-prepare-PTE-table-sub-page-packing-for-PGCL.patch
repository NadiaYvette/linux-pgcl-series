From 57ea2d9cec35008bf639429ade34123cd52d7823 Mon Sep 17 00:00:00 2001
From: Nadia Chambers <nadia.yvette.chambers@ik.me>
Date: Tue, 12 May 2026 00:07:56 +0200
Subject: [PATCH 109/174] mips: prepare PTE-table sub-page packing for PGCL

Under PGCL the buddy allocator hands out PAGE_SIZE chunks while a
hardware PTE table is only MMUPAGE_SIZE.  On mips64 malta with
CONFIG_PAGE_SIZE_16KB and CONFIG_PAGE_MMUSHIFT=6 that means each
pte_alloc_one() takes a 1MB kernel page to hold a 16KB hardware table
-- 64x waste per allocation.  An OOM dump from a fork-heavy LTP run
shows pagetables: 739328 kB, ~35 % of total RAM, so this is by far
the dominant memory pressure at PAGE_MMUSHIFT=6.

Lay the groundwork to pack PAGE_MMUCOUNT MMUPAGE-sized PTE sub-tables
into one kernel page (m68k's get_pointer_table / free_pointer_table
pattern; sparc64-style pgtable_t = pte_t *):

  * arch/mips/include/asm/page.h: pgtable_t is now pte_t *, not
    struct page *.  This lets one struct page (= one ptdesc) host
    multiple sub-table pgtable_t pointers without any struct-page
    encoding tricks.

  * arch/mips/include/asm/pgalloc.h: drop asm-generic/pgalloc.h (its
    __pte_alloc_one_noprof returns ptdesc_page(), incompatible with
    pte_t *), provide every entry point explicitly (sparc64 model).
    pmd_populate now installs the pte_t * directly -- no
    page_address(pgtable_t) round-trip -- so a sub-table address at
    non-zero offset within a kernel page works as-is.  Define
    pmd_pgtable() to read the address back out of pmd_val(pmd) via
    pmd_page_vaddr().  __pte_free_tlb() calls our pte_free directly
    rather than tlb_remove_ptdesc() (which would prematurely return
    the kernel page hosting other live sub-tables).

  * arch/mips/include/asm/pgtable-{32,64}.h: pmd_bad() / pud_bad() /
    p4d_bad() previously checked pmd_val(pmd) & ~PAGE_MASK, treating
    any non-PAGE-aligned PMD as corrupt.  PTE tables are MMUPAGE-
    aligned, not PAGE-aligned, so packed sub-tables at offsets
    16K, 32K, ... within a kernel page would all trip that check (and
    do, with packing on -- spam 'bad pmd ...' until oom-killer fires).
    Use ~MMUPAGE_MASK.

  * arch/mips/mm/pgtable.c: pgd_alloc() inlines pagetable_alloc +
    pagetable_pgd_ctor since asm-generic's __pgd_alloc helper is no
    longer in scope.

  * arch/mips/mm/pgtable_pte.c (new): the packed allocator itself.
    Per-type free list of ptdescs with at least one free sub-table;
    pt_index holds a 64-bit markbits bitmap (bit N => sub-table N at
    offset N*MMUPAGE_SIZE is free); pt_list links the ptdesc into
    pte_user_free_list / pte_kernel_free_list.  All sub-tables share
    the single ptl_lock allocated by pagetable_pte_ctor() -- a
    deliberate trade of locking granularity for a 64x reduction in
    pgtable footprint.

PTE_PER_PAGE is currently set to 1, which makes the allocator
degenerate to "one PTE table per kernel page, return to buddy on free"
-- behaviorally identical to the pre-patch state, but on top of the
pgtable_t = pte_t * scaffold needed to enable real packing.  Switching
PTE_PER_PAGE back to PAGE_MMUCOUNT (or any value > 1) silently hangs
init early in busybox startup; the typedef change and pmd_bad fix are
correct in isolation (no-reuse mode with PTE_PER_PAGE=64 boots and
runs LTP) but the reuse path triggers a slowdown / lockup that I
haven't isolated yet.  Likely culprits: stale TLB-cached PTE-table
contents when a freed sub-table is immediately reallocated for a
different mm; pagetable_pte_ctor / ptlock_init ordering across
sub-tables; or split-ptlock semantics for sub-tables that share one
ptl.  Filed as TODO -- once diagnosed, just flip PTE_PER_PAGE.

Test results (mips64 malta -m2G, init=autotest LTP mm):
  PAGE_MMUSHIFT=4 before: 67p/3f/31s
  PAGE_MMUSHIFT=4 after:  67p/3f/31s (identical, no regression)
  PAGE_MMUSHIFT=6 before: 59p/11f/31s (post-shm_align_mask fix)
  PAGE_MMUSHIFT=6 after:  58p/12f/31s (within OOM-cascade noise)

No memory-pressure improvement yet -- that depends on enabling the
real packing.  The point of this commit is to land the type and
header changes so the future packing work doesn't have to re-do them.

Signed-off-by: Nadia Chambers <nadia.yvette.chambers@gmail.com>
---
 arch/mips/include/asm/page.h       |  10 +-
 arch/mips/include/asm/pgalloc.h    |  67 +++++++++--
 arch/mips/include/asm/pgtable-32.h |   3 +-
 arch/mips/include/asm/pgtable-64.h |  14 ++-
 arch/mips/mm/Makefile              |   1 +
 arch/mips/mm/pgtable.c             |  18 +--
 arch/mips/mm/pgtable_pte.c         | 186 +++++++++++++++++++++++++++++
 7 files changed, 280 insertions(+), 19 deletions(-)
 create mode 100644 arch/mips/mm/pgtable_pte.c

diff --git a/arch/mips/include/asm/page.h b/arch/mips/include/asm/page.h
index d8ac3640a00e..73fe212c3a7e 100644
--- a/arch/mips/include/asm/page.h
+++ b/arch/mips/include/asm/page.h
@@ -116,7 +116,15 @@ typedef struct { unsigned long pte; } pte_t;
 #define pte_val(x)	((x).pte)
 #define __pte(x)	((pte_t) { (x) } )
 #endif
-typedef struct page *pgtable_t;
+/*
+ * pgtable_t is the type passed to pmd_populate() / pte_free() and stored in
+ * the deposited-pgtable list for THP.  Use pte_t * directly (the address of
+ * the actual hardware PTE table) rather than struct page * so that PGCL can
+ * pack multiple MMUPAGE-sized PTE tables into one kernel PAGE_SIZE chunk:
+ * each sub-table has its own pte_t * but maps to the same struct page.
+ * Modeled after sparc64 / m68k-coldfire.
+ */
+typedef pte_t *pgtable_t;
 
 /*
  * Right now we don't support 4-level pagetables, so all pud-related
diff --git a/arch/mips/include/asm/pgalloc.h b/arch/mips/include/asm/pgalloc.h
index 9ec9cf01e92e..239eb66ab5a8 100644
--- a/arch/mips/include/asm/pgalloc.h
+++ b/arch/mips/include/asm/pgalloc.h
@@ -13,9 +13,16 @@
 #include <linux/mm.h>
 #include <linux/sched.h>
 
-#define __HAVE_ARCH_PMD_ALLOC_ONE
-#define __HAVE_ARCH_PUD_ALLOC_ONE
-#include <asm-generic/pgalloc.h>
+/*
+ * Don't pull in asm-generic/pgalloc.h: pgtable_t is pte_t * on mips
+ * (so PGCL can pack many MMUPAGE-sized PTE tables into one PAGE_SIZE
+ * chunk), which is incompatible with the generic helpers that return
+ * struct page *.  Provide every entry point explicitly here, mirroring
+ * sparc64's approach.
+ */
+
+#define GFP_PGTABLE_KERNEL	(GFP_KERNEL | __GFP_ZERO)
+#define GFP_PGTABLE_USER	(GFP_PGTABLE_KERNEL | __GFP_ACCOUNT)
 
 static inline void pmd_populate_kernel(struct mm_struct *mm, pmd_t *pmd,
 	pte_t *pte)
@@ -23,12 +30,25 @@ static inline void pmd_populate_kernel(struct mm_struct *mm, pmd_t *pmd,
 	set_pmd(pmd, __pmd((unsigned long)pte));
 }
 
+/*
+ * pgtable_t is pte_t * on mips (see asm/page.h), so pmd_populate is
+ * identical to pmd_populate_kernel: install the PTE-table virtual
+ * address directly, no struct page round-trip.
+ */
 static inline void pmd_populate(struct mm_struct *mm, pmd_t *pmd,
 	pgtable_t pte)
 {
-	set_pmd(pmd, __pmd((unsigned long)page_address(pte)));
+	set_pmd(pmd, __pmd((unsigned long)pte));
 }
 
+/*
+ * Override the asm-generic pmd_pgtable (defined in include/linux/pgtable.h
+ * as pmd_page(pmd) — i.e. struct page *) with the pte_t * form, since
+ * pgtable_t is pte_t * on mips.  Pre-empt the generic definition.
+ */
+#undef pmd_pgtable
+#define pmd_pgtable(pmd)	((pte_t *)pmd_page_vaddr(pmd))
+
 /*
  * Initialize a new pmd table with invalid pointers.
  */
@@ -48,7 +68,26 @@ static inline void pud_populate(struct mm_struct *mm, pud_t *pud, pmd_t *pmd)
 extern void pgd_init(void *addr);
 extern pgd_t *pgd_alloc(struct mm_struct *mm);
 
-#define __pte_free_tlb(tlb, pte, address)	tlb_remove_ptdesc((tlb), page_ptdesc(pte))
+static inline void pgd_free(struct mm_struct *mm, pgd_t *pgd)
+{
+	pagetable_dtor_free(virt_to_ptdesc(pgd));
+}
+
+/* PTE allocator (PGCL sub-page packed) — see arch/mips/mm/pgtable_pte.c */
+extern pte_t *pte_alloc_one_kernel(struct mm_struct *mm);
+extern pgtable_t pte_alloc_one(struct mm_struct *mm);
+extern void pte_free_kernel(struct mm_struct *mm, pte_t *pte);
+extern void pte_free(struct mm_struct *mm, pgtable_t pte);
+
+/*
+ * The TLB-gather PTE-table free path can't batch sub-table frees through
+ * tlb_remove_ptdesc (which would prematurely release the kernel page that
+ * still hosts other live sub-tables).  Just call our packed pte_free
+ * directly here; the eventual tlb_finish_mmu() flushes the TLB before
+ * the freed sub-table can be observed by user mode.
+ */
+#define __pte_free_tlb(tlb, pte, address)			\
+	pte_free((tlb)->mm, (pte))
 
 #ifndef __PAGETABLE_PMD_FOLDED
 
@@ -57,7 +96,8 @@ static inline pmd_t *pmd_alloc_one(struct mm_struct *mm, unsigned long address)
 	pmd_t *pmd;
 	struct ptdesc *ptdesc;
 
-	ptdesc = pagetable_alloc(GFP_KERNEL_ACCOUNT, PMD_TABLE_ORDER);
+	ptdesc = pagetable_alloc(GFP_KERNEL_ACCOUNT | __GFP_ZERO,
+				 PMD_TABLE_ORDER);
 	if (!ptdesc)
 		return NULL;
 
@@ -71,6 +111,12 @@ static inline pmd_t *pmd_alloc_one(struct mm_struct *mm, unsigned long address)
 	return pmd;
 }
 
+static inline void pmd_free(struct mm_struct *mm, pmd_t *pmd)
+{
+	BUG_ON((unsigned long)pmd & (MMUPAGE_SIZE - 1));
+	pagetable_dtor_free(virt_to_ptdesc(pmd));
+}
+
 #define __pmd_free_tlb(tlb, x, addr)	tlb_remove_ptdesc((tlb), virt_to_ptdesc(x))
 
 #endif
@@ -80,7 +126,8 @@ static inline pmd_t *pmd_alloc_one(struct mm_struct *mm, unsigned long address)
 static inline pud_t *pud_alloc_one(struct mm_struct *mm, unsigned long address)
 {
 	pud_t *pud;
-	struct ptdesc *ptdesc = pagetable_alloc(GFP_KERNEL, PUD_TABLE_ORDER);
+	struct ptdesc *ptdesc = pagetable_alloc(GFP_KERNEL | __GFP_ZERO,
+						PUD_TABLE_ORDER);
 
 	if (!ptdesc)
 		return NULL;
@@ -91,6 +138,12 @@ static inline pud_t *pud_alloc_one(struct mm_struct *mm, unsigned long address)
 	return pud;
 }
 
+static inline void pud_free(struct mm_struct *mm, pud_t *pud)
+{
+	BUG_ON((unsigned long)pud & (MMUPAGE_SIZE - 1));
+	pagetable_dtor_free(virt_to_ptdesc(pud));
+}
+
 static inline void p4d_populate(struct mm_struct *mm, p4d_t *p4d, pud_t *pud)
 {
 	set_p4d(p4d, __p4d((unsigned long)pud));
diff --git a/arch/mips/include/asm/pgtable-32.h b/arch/mips/include/asm/pgtable-32.h
index f8e213feaddf..263b0f6c8d81 100644
--- a/arch/mips/include/asm/pgtable-32.h
+++ b/arch/mips/include/asm/pgtable-32.h
@@ -138,7 +138,8 @@ static inline int pmd_bad(pmd_t pmd)
 		return 0;
 #endif
 
-	if (unlikely(pmd_val(pmd) & ~PAGE_MASK))
+	/* See pgtable-64.h pmd_bad() comment: PTE sub-tables are MMUPAGE-aligned. */
+	if (unlikely(pmd_val(pmd) & ~MMUPAGE_MASK))
 		return 1;
 
 	return 0;
