 	if (vma_flags_test(&vma_flags, VMA_LOCKED_BIT))
-		mm->locked_vm += (len >> PAGE_SHIFT);
+		mm->locked_vm += (len >> MMUPAGE_SHIFT);
 	if (pgtable_supports_soft_dirty())
 		vma_set_flags(vma, VMA_SOFTDIRTY_BIT);
 	return 0;
@@ -2948,7 +2948,7 @@ int do_brk_flags(struct vma_iterator *vmi, struct vm_area_struct *vma,
 mas_store_fail:
 	vm_area_free(vma);
 unacct_fail:
-	vm_unacct_memory(len >> PAGE_SHIFT);
+	vm_unacct_memory(len >> MMUPAGE_SHIFT);
 	return -ENOMEM;
 }
 
