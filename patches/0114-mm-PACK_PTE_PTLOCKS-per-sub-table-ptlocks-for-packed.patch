From a5c3cd9ebc2b71d0a89a1cfc8eb0e5e20c4a8a73 Mon Sep 17 00:00:00 2001
From: Nadia Chambers <nadia.yvette.chambers@ik.me>
Date: Wed, 13 May 2026 02:11:11 +0200
Subject: [PATCH 114/174] =?UTF-8?q?mm:=20PACK=5FPTE=5FPTLOCKS=20=E2=80=94?=
 =?UTF-8?q?=20per-sub-table=20ptlocks=20for=20packed=20PTE=20tables?=
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

When an architecture packs multiple MMUPAGE-sized PTE tables into a
single PAGE_SIZE ptdesc (mips PGCL today, generalisable to sparc32,
s390 PGCL, powerpc pte_fragment), naive per-ptdesc ptlocks deadlock
in copy_page_range() during fork.  Two PTE tables that happen to share
a kernel page resolve to the same per-ptdesc spinlock, and the nested
spin_lock_nested() with SINGLE_DEPTH_NESTING then takes the same lock
twice.  The previous workaround for mips at 86b2de5d2c01 disabled
SPLIT_PTE_PTLOCKS for mips PGCL entirely (matching the SPARC32 rule),
which lost SMP scalability.

This adds a CONFIG_PACK_PTE_PTLOCKS opt-in that the affected arch can
select.  When on:

  - ALLOC_SPLIT_PTLOCKS is forced 1 so ptdesc->ptl is a pointer
  - the page->ptl kmem_cache is sized for PTE_PACK_NR spinlocks
  - ptlock_init initialises the entire array
  - pte_lockptr / ptep_lockptr index by sub-table position via a
    new pte_pack_index(addr) helper

PTE_PACK_ORDER defaults to 0; the arch overrides it in <asm/page.h>.
At order 0, pte_pack_index returns constant 0 and the array
degenerates to a single lock — the historical behaviour, preserved
bit-for-bit for non-packing arches.

Wires mips: arch/mips/Kconfig selects PACK_PTE_PTLOCKS when
PAGE_MMUSHIFT > 0, and arch/mips/include/asm/page.h sets
PTE_PACK_ORDER = PAGE_MMUSHIFT (so the 64-way packing at PGCL=6 gets a
64-element ptlock array per ptdesc).  mm/Kconfig drops the !MIPS
guard on SPLIT_PTE_PTLOCKS that 86b2de5d2c01 added.

Verification:
  - smatch (Fedora 1.73) clean across changed files
  - herd7 LKMM litmus test of pmd → ptdesc → ptl[i] address-dependency
    chain returns Never for the publication-race outcome
  - LOCKDEP + PROVE_LOCKING + KCSAN + DEBUG_SPINLOCK + SLUB_DEBUG_ON
    boots clean — no recursive lock, no data race, no slab corruption
  - 25 / 25 boots PASS on mips64 malta -m2G PGCL=6 (after the
    independent mips_stack_top PAGE-alignment fix at 50e3c2115ab8;
    without that fix, PACK_PTE_PTLOCKS exposes a separate vDSO
    MAP_FIXED bug at ~12 % per boot).

Cost: PTE_PACK_NR * sizeof(spinlock_t) per ptdesc — 256 bytes at
PAGE_MMUSHIFT=6 with queued spinlocks — and one extra indirection
in pte_lockptr.  Both gated by the opt-in CONFIG.

Signed-off-by: Nadia Yvette Chambers <nadia.yvette.chambers@gmail.com>
---
 arch/mips/Kconfig             |  4 ++++
 arch/mips/include/asm/page.h  | 11 +++++++++++
 include/linux/mm.h            | 30 +++++++++++++++++++++++++++---
 include/linux/mm_types_task.h | 11 +++++++++++
 mm/Kconfig                    | 19 ++++++++++++++-----
 mm/memory.c                   | 10 ++++++++--
 6 files changed, 75 insertions(+), 10 deletions(-)

diff --git a/arch/mips/Kconfig b/arch/mips/Kconfig
index beae0056bc47..36b94ba50629 100644
--- a/arch/mips/Kconfig
+++ b/arch/mips/Kconfig
@@ -25,6 +25,10 @@ config MIPS
 	select ARCH_USE_MEMTEST
 	select ARCH_USE_QUEUED_RWLOCKS
 	select ARCH_USE_QUEUED_SPINLOCKS
+	# PGCL packs PAGE_MMUCOUNT MMUPAGE-sized PTE tables into one
+	# PAGE_SIZE ptdesc; ask for one ptlock per sub-table so that
+	# SPLIT_PTE_PTLOCKS keeps working under PGCL.
+	select PACK_PTE_PTLOCKS if PAGE_MMUSHIFT > 0
 	select ARCH_SUPPORTS_HUGETLBFS if CPU_SUPPORTS_HUGEPAGES
 	select ARCH_WANT_DEFAULT_TOPDOWN_MMAP_LAYOUT if MMU
 	select ARCH_WANT_IPC_PARSE_VERSION
diff --git a/arch/mips/include/asm/page.h b/arch/mips/include/asm/page.h
index 73fe212c3a7e..f7870e268b4d 100644
--- a/arch/mips/include/asm/page.h
+++ b/arch/mips/include/asm/page.h
@@ -16,6 +16,17 @@
 
 #include <vdso/page.h>
 
+#ifdef CONFIG_PACK_PTE_PTLOCKS
+/*
+ * mips packs PAGE_MMUCOUNT MMUPAGE-sized PTE tables into one PAGE_SIZE
+ * ptdesc; tell the generic ptlock allocator to size the per-ptdesc lock
+ * array accordingly so each sub-table has its own spinlock and
+ * copy_page_range() doesn't deadlock when src and dst share a ptdesc.
+ * See arch/mips/mm/pgtable_pte.c.
+ */
+#define PTE_PACK_ORDER	PAGE_MMUSHIFT
+#endif
+
 /*
  * This is used for calculating the real page sizes
  * for FTLB or VTLB + FTLB configurations.
diff --git a/include/linux/mm.h b/include/linux/mm.h
index 0c16089975a4..dcba34277abf 100644
--- a/include/linux/mm.h
+++ b/include/linux/mm.h
@@ -3752,6 +3752,24 @@ static inline void pagetable_free(struct ptdesc *pt)
 }
 
 #if defined(CONFIG_SPLIT_PTE_PTLOCKS)
+/*
+ * PTE_PACK_ORDER: log2 of how many MMUPAGE-sized PTE tables share one
+ * PAGE_SIZE ptdesc.  Default 0 (no packing).  Architectures that opt
+ * into PTE table packing (CONFIG_PACK_PTE_PTLOCKS) override this in
+ * <asm/page.h>.  At order 0, pte_pack_index() is constant 0 and the
+ * spinlock array degenerates to a single lock — the historical
+ * behaviour, preserved bit-for-bit for non-packing arches.
+ */
+#ifndef PTE_PACK_ORDER
+#define PTE_PACK_ORDER 0
+#endif
+#define PTE_PACK_NR (1U << PTE_PACK_ORDER)
+
+static inline unsigned int pte_pack_index(unsigned long addr)
+{
+	return (addr >> MMUPAGE_SHIFT) & (PTE_PACK_NR - 1);
+}
+
 #if ALLOC_SPLIT_PTLOCKS
 void __init ptlock_cache_init(void);
 bool ptlock_alloc(struct ptdesc *ptdesc);
@@ -3783,18 +3801,23 @@ static inline spinlock_t *ptlock_ptr(struct ptdesc *ptdesc)
 
 static inline spinlock_t *pte_lockptr(struct mm_struct *mm, pmd_t *pmd)
 {
-	return ptlock_ptr(page_ptdesc(pmd_page(*pmd)));
+	struct ptdesc *pt = page_ptdesc(pmd_page(*pmd));
+	unsigned long pmdv = (unsigned long)pmd_page_vaddr(*pmd);
+
+	return &ptlock_ptr(pt)[pte_pack_index(pmdv)];
 }
 
 static inline spinlock_t *ptep_lockptr(struct mm_struct *mm, pte_t *pte)
 {
 	BUILD_BUG_ON(IS_ENABLED(CONFIG_HIGHPTE));
 	BUILD_BUG_ON(MAX_PTRS_PER_PTE * sizeof(pte_t) > PAGE_SIZE);
-	return ptlock_ptr(virt_to_ptdesc(pte));
+	return &ptlock_ptr(virt_to_ptdesc(pte))[pte_pack_index((unsigned long)pte)];
 }
 
 static inline bool ptlock_init(struct ptdesc *ptdesc)
 {
+	unsigned int i;
+
 	/*
 	 * prep_new_page() initialize page->private (and therefore page->ptl)
 	 * with 0. Make sure nobody took it in use in between.
@@ -3805,7 +3828,8 @@ static inline bool ptlock_init(struct ptdesc *ptdesc)
 	VM_BUG_ON_PAGE(*(unsigned long *)&ptdesc->ptl, ptdesc_page(ptdesc));
 	if (!ptlock_alloc(ptdesc))
 		return false;
-	spin_lock_init(ptlock_ptr(ptdesc));
+	for (i = 0; i < PTE_PACK_NR; i++)
+		spin_lock_init(&ptlock_ptr(ptdesc)[i]);
 	return true;
 }
 
diff --git a/include/linux/mm_types_task.h b/include/linux/mm_types_task.h
index 11bf319d78ec..a9e7a5d7caa3 100644
--- a/include/linux/mm_types_task.h
+++ b/include/linux/mm_types_task.h
@@ -17,7 +17,18 @@
 #include <asm/tlbbatch.h>
 #endif
 
+/*
+ * When PACK_PTE_PTLOCKS is on, an architecture packs multiple
+ * MMUPAGE-sized PTE tables into a single PAGE_SIZE ptdesc; the ptdesc
+ * therefore carries an array of spinlocks (one per sub-table) that must
+ * be dynamically allocated regardless of spinlock_t size.  Force the
+ * ALLOC_SPLIT_PTLOCKS path so ptdesc->ptl is a pointer.
+ */
+#ifdef CONFIG_PACK_PTE_PTLOCKS
+#define ALLOC_SPLIT_PTLOCKS	1
+#else
 #define ALLOC_SPLIT_PTLOCKS	(SPINLOCK_SIZE > BITS_PER_LONG/8)
+#endif
 
 /*
  * When updating this, please also update struct resident_page_types[] in
diff --git a/mm/Kconfig b/mm/Kconfig
index d37ea6cfbe3b..bf7e4e4ef743 100644
--- a/mm/Kconfig
+++ b/mm/Kconfig
@@ -570,14 +570,23 @@ config SPLIT_PTE_PTLOCKS
 	depends on !ARM || CPU_CACHE_VIPT
 	depends on !PARISC || PA20
 	depends on !S390 || PAGE_MMUSHIFT = 0
-	# MIPS packs MMUPAGE-sized PTE tables into PAGE_SIZE chunks
-	# under PGCL (see arch/mips/mm/pgtable_pte.c) so multiple PTE
-	# tables share a kernel page; per-page split ptlocks deadlock
-	# in copy_page_range() exactly as on SPARC32.
-	depends on !MIPS || PAGE_MMUSHIFT = 0
 	depends on !SPARC32
 	depends on !UML
 
+#
+# When an architecture packs N > 1 MMUPAGE-sized PTE tables into a single
+# PAGE_SIZE ptdesc (mips PGCL today; generalisable to sparc32, s390 PGCL,
+# powerpc pte_fragment), naive per-ptdesc ptlocks deadlock in
+# copy_page_range() because two sub-tables sharing a ptdesc share a lock.
+# Selecting PACK_PTE_PTLOCKS allocates one spinlock per sub-table in an
+# array hung off ptdesc->ptl, indexed by the sub-table offset within the
+# kernel page; SPLIT_PTE_PTLOCKS continues to apply.
+#
+config PACK_PTE_PTLOCKS
+	bool
+	depends on SPLIT_PTE_PTLOCKS
+	depends on PAGE_MMUSHIFT > 0
+
 config ARCH_ENABLE_SPLIT_PMD_PTLOCK
 	bool
 
diff --git a/mm/memory.c b/mm/memory.c
index 03c507245151..4453552387bb 100644
--- a/mm/memory.c
+++ b/mm/memory.c
@@ -8119,8 +8119,14 @@ static struct kmem_cache *page_ptl_cachep;
 
 void __init ptlock_cache_init(void)
 {
-	page_ptl_cachep = kmem_cache_create("page->ptl", sizeof(spinlock_t), 0,
-			SLAB_PANIC, NULL);
+	/*
+	 * Each ptdesc may host PTE_PACK_NR sub-tables (PACK_PTE_PTLOCKS);
+	 * size the cache to hold one spinlock per sub-table.  At PTE_PACK_NR
+	 * = 1 (the default for non-packing arches) this is the historical
+	 * single-spinlock allocation, unchanged.
+	 */
+	page_ptl_cachep = kmem_cache_create("page->ptl",
+			PTE_PACK_NR * sizeof(spinlock_t), 0, SLAB_PANIC, NULL);
 }
 
 bool ptlock_alloc(struct ptdesc *ptdesc)
-- 
2.54.0

